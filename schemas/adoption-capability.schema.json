{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wordpress-hx.dev/schemas/adoption-capability.schema.json",
  "title": "WordPressHx provider capability declarations",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schemaVersion",
    "capabilitySetId",
    "capabilitySetVersion",
    "contract",
    "profile",
    "provider",
    "authority",
    "capabilities",
    "capabilitySetDigest"
  ],
  "properties": {
    "schema": {
      "const": "wordpress-hx.adoption-capability.v1"
    },
    "schemaVersion": {
      "const": 1
    },
    "capabilitySetId": {
      "$ref": "#/$defs/id"
    },
    "capabilitySetVersion": {
      "$ref": "#/$defs/semver"
    },
    "contract": {
      "$ref": "#/$defs/contractRef"
    },
    "profile": {
      "$ref": "#/$defs/profileRef"
    },
    "provider": {
      "$ref": "#/$defs/providerRef"
    },
    "authority": {
      "$ref": "#/$defs/authority"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/capability"
      }
    },
    "capabilitySetDigest": {
      "$ref": "#/$defs/sha256"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*"
    },
    "sha256": {
      "type": "string",
      "pattern": "[0-9a-f]{64}"
    },
    "semver": {
      "type": "string",
      "pattern": "(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?"
    },
    "contractRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "sha256"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "profileRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "catalogRevision", "catalogSha256"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "catalogRevision": {
          "type": "string",
          "pattern": "[a-z0-9-]+/catalog-v[1-9][0-9]*"
        },
        "catalogSha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "providerRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "artifactSha256"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "artifactSha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokenScope",
        "tokenSerializable",
        "tokenCacheable",
        "staleTokenAuthority",
        "absenceBehavior",
        "providerTrustAdmission"
      ],
      "properties": {
        "tokenScope": {
          "const": "declared-per-capability"
        },
        "tokenSerializable": {
          "const": false
        },
        "tokenCacheable": {
          "const": false
        },
        "staleTokenAuthority": {
          "const": false
        },
        "absenceBehavior": {
          "const": "typed-unavailable-with-core-fallback"
        },
        "providerTrustAdmission": {
          "const": "separate-sdk-117-requirement"
        }
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "requiredBindings",
        "requiredNativeSymbols",
        "versionMatch",
        "artifactMatch",
        "conditionalFailure"
      ],
      "properties": {
        "kind": {
          "enum": [
            "php-symbols",
            "javascript-exports",
            "wordpress-plugin-and-symbols",
            "composite"
          ]
        },
        "requiredBindings": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "requiredNativeSymbols": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "versionMatch": {
          "const": "exact"
        },
        "artifactMatch": {
          "const": "exact-sha256"
        },
        "conditionalFailure": {
          "const": "unavailable-not-partially-authorized"
        }
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "target", "scope", "optional", "probe"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "target": {
          "enum": ["php", "javascript", "wordpress", "cross-target"]
        },
        "scope": {
          "enum": ["request", "process", "browser-module"]
        },
        "optional": {
          "type": "boolean"
        },
        "probe": {
          "$ref": "#/$defs/probe"
        }
      }
    }
  }
}
