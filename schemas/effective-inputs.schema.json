{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fullofcaffeine/wordpresshx/schemas/effective-inputs.schema.json",
  "title": "WordPressHx deterministic effective-input graph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "canonicalization",
    "fingerprintAlgorithm",
    "fingerprint",
    "project",
    "profile",
    "files",
    "discoveryRoots",
    "watchRoots",
    "ignoredRoots",
    "toolchain",
    "environment",
    "compileServer"
  ],
  "properties": {
    "schema": {
      "const": "wordpress-hx.effective-inputs.v1"
    },
    "canonicalization": {
      "const": "wordpress-hx.canonical-json.v1"
    },
    "fingerprintAlgorithm": {
      "const": "sha256-canonical-json-without-fingerprint-v1"
    },
    "fingerprint": {
      "$ref": "#/$defs/sha256"
    },
    "project": {
      "$ref": "#/$defs/project"
    },
    "profile": {
      "$ref": "#/$defs/profile"
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/file"
      }
    },
    "discoveryRoots": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/discoveryRoot"
      }
    },
    "watchRoots": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/relativePath"
      }
    },
    "ignoredRoots": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/relativePath"
      }
    },
    "toolchain": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/tool"
      }
    },
    "environment": {
      "$ref": "#/$defs/environment"
    },
    "compileServer": {
      "$ref": "#/$defs/compileServer"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "stableId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._:/-][a-z0-9]+)*$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._@+-]+(?:/[A-Za-z0-9._@+-]+)*$"
    },
    "environmentName": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "glob": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)[A-Za-z0-9._@+*?{}/,-]+$"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "configPath",
        "configSemanticSha256",
        "lockPath",
        "lockFileSha256",
        "lockDigest"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/stableId"
        },
        "configPath": {
          "$ref": "#/$defs/relativePath"
        },
        "configSemanticSha256": {
          "$ref": "#/$defs/sha256"
        },
        "lockPath": {
          "$ref": "#/$defs/relativePath"
        },
        "lockFileSha256": {
          "$ref": "#/$defs/sha256"
        },
        "lockDigest": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "catalogRevision",
        "catalogSha256"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/stableId"
        },
        "catalogRevision": {
          "type": "string",
          "minLength": 1
        },
        "catalogSha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "byteLength",
        "role",
        "targets"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "byteLength": {
          "type": "integer",
          "minimum": 0
        },
        "role": {
          "enum": [
            "project-config",
            "project-lock",
            "haxe-config",
            "haxe-source",
            "hxml",
            "asset",
            "package-manifest",
            "package-lock",
            "macro-external"
          ]
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "plan",
              "php",
              "browser",
              "metadata",
              "assets",
              "services",
              "test"
            ]
          }
        }
      }
    },
    "discoveryRoot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "includes",
        "excludes",
        "targets"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "includes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/glob"
          }
        },
        "excludes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/glob"
          }
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "plan",
              "php",
              "browser",
              "metadata",
              "assets",
              "services",
              "test"
            ]
          }
        }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "identity",
        "lockEntrySha256"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/stableId"
        },
        "identity": {
          "type": "string",
          "minLength": 1
        },
        "lockEntrySha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "buildEnvironment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "source",
        "valueSha256"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/environmentName"
        },
        "source": {
          "enum": [
            "default",
            "process"
          ]
        },
        "valueSha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "build",
        "runtimeExcluded"
      ],
      "properties": {
        "build": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/buildEnvironment"
          }
        },
        "runtimeExcluded": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/environmentName"
          }
        }
      }
    },
    "compileServer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy",
        "compatibilityDigestAlgorithm",
        "compatibilityDigest",
        "compatibilityComponents",
        "restartFileRoles",
        "directBuildDefault"
      ],
      "properties": {
        "policy": {
          "const": "project-isolated-compatible-attach-v1"
        },
        "compatibilityDigestAlgorithm": {
          "const": "sha256-project-lock-config-compiler-and-build-env-v1"
        },
        "compatibilityDigest": {
          "$ref": "#/$defs/sha256"
        },
        "compatibilityComponents": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/stableId"
          }
        },
        "restartFileRoles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "project-config",
              "project-lock",
              "haxe-config",
              "hxml",
              "package-manifest",
              "package-lock"
            ]
          }
        },
        "directBuildDefault": {
          "type": "boolean"
        }
      }
    }
  }
}
