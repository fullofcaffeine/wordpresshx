{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fullofcaffeine/wordpresshx/schemas/cli-event.schema.json",
  "title": "WordPressHx CLI JSONL event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "runId",
    "sequence",
    "elapsedMs",
    "command",
    "event",
    "stage",
    "status",
    "payload"
  ],
  "properties": {
    "schema": {
      "const": "wordpress-hx.cli-event.v1"
    },
    "runId": {
      "$ref": "#/$defs/stableId"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "elapsedMs": {
      "type": "integer",
      "minimum": 0
    },
    "command": {
      "enum": [
        "init",
        "new",
        "add",
        "generate",
        "adopt",
        "profile",
        "lock",
        "build",
        "check",
        "clean",
        "dev",
        "doctor",
        "inspect",
        "trace",
        "diff-profile",
        "upgrade",
        "package",
        "test"
      ]
    },
    "event": {
      "enum": [
        "command-started",
        "stage-started",
        "stage-completed",
        "stage-skipped",
        "build-published",
        "build-retained",
        "dry-run-planned",
        "compiler-server-ready",
        "change-detected",
        "rebuild-scheduled",
        "diagnostic",
        "service-starting",
        "service-ready",
        "service-stopped",
        "watch-ready",
        "reload-requested",
        "shutdown-started",
        "command-completed"
      ]
    },
    "stage": {
      "enum": [
        "command",
        "configuration",
        "profile-resolution",
        "haxe-typing-and-plan",
        "php-emission",
        "browser-emission",
        "metadata-emission",
        "format-and-static-check",
        "asset-build",
        "artifact-validation",
        "ownership-publish",
        "compiler-server",
        "service-start",
        "service-readiness",
        "watching",
        "shutdown"
      ]
    },
    "status": {
      "enum": [
        "started",
        "running",
        "passed",
        "failed",
        "retained",
        "ready",
        "skipped",
        "stopped",
        "interrupted"
      ]
    },
    "payload": {
      "$ref": "#/$defs/payload"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "stableId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._:/-][a-z0-9]+)*$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._@+-]+(?:/[A-Za-z0-9._@+-]+)*$"
    },
    "loopbackUrl": {
      "type": "string",
      "pattern": "^https?://(?:localhost|127\\.0\\.0\\.1|\\[::1\\])(?::(?:[1-9][0-9]{0,3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5]))?(?:/[A-Za-z0-9._~!$&'()*+,;=:@%/-]*)?$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "line",
        "column"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "column": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "severity",
        "message",
        "profile",
        "source",
        "remediations",
        "reference"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^WPHX[0-9]{4}$"
        },
        "severity": {
          "enum": [
            "error",
            "warning",
            "info"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "profile": {
          "$ref": "#/$defs/stableId"
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "generatedPath": {
          "$ref": "#/$defs/relativePath"
        },
        "expected": {
          "type": "string"
        },
        "actual": {
          "type": "string"
        },
        "remediations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reference": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "enum": [
            "initial",
            "rebuild",
            "dry-run",
            "shutdown"
          ]
        },
        "buildId": {
          "$ref": "#/$defs/stableId"
        },
        "fingerprint": {
          "$ref": "#/$defs/sha256"
        },
        "changedPaths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/relativePath"
          }
        },
        "coalescedChanges": {
          "type": "integer",
          "minimum": 1
        },
        "generation": {
          "type": "integer",
          "minimum": 1
        },
        "manifestDigest": {
          "$ref": "#/$defs/sha256"
        },
        "retainedManifestDigest": {
          "$ref": "#/$defs/sha256"
        },
        "serverCompatibilityDigest": {
          "$ref": "#/$defs/sha256"
        },
        "serviceId": {
          "$ref": "#/$defs/stableId"
        },
        "serviceKind": {
          "enum": [
            "compiler",
            "wordpress",
            "nextjs",
            "external"
          ]
        },
        "processOwnership": {
          "enum": [
            "owned",
            "compatible-attached"
          ]
        },
        "url": {
          "$ref": "#/$defs/loopbackUrl"
        },
        "readiness": {
          "enum": [
            "http",
            "tcp",
            "process",
            "log",
            "none"
          ]
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1
        },
        "diagnostic": {
          "$ref": "#/$defs/diagnostic"
        },
        "reload": {
          "enum": [
            "full-page",
            "native-hmr",
            "none"
          ]
        },
        "exitCode": {
          "type": "integer",
          "minimum": 0
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
