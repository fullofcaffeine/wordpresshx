{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fullofcaffeine/wordpresshx/schemas/project-lock.schema.json",
  "title": "WordPressHx exact project lock",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "canonicalization",
    "lockDigestAlgorithm",
    "lockDigest",
    "generatedBy",
    "project",
    "profile",
    "components",
    "packageGraph"
  ],
  "properties": {
    "schema": {
      "const": "wordpress-hx.project-lock.v1"
    },
    "canonicalization": {
      "const": "wordpress-hx.canonical-json.v1"
    },
    "lockDigestAlgorithm": {
      "const": "sha256-canonical-json-without-lockDigest-v1"
    },
    "lockDigest": {
      "$ref": "#/$defs/sha256"
    },
    "generatedBy": {
      "$ref": "#/$defs/generatedBy"
    },
    "project": {
      "$ref": "#/$defs/project"
    },
    "profile": {
      "$ref": "#/$defs/profile"
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/component"
      }
    },
    "packageGraph": {
      "$ref": "#/$defs/packageGraph"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "exactVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
    },
    "stableId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._:/-][a-z0-9]+)*$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._@+-]+(?:/[A-Za-z0-9._@+-]+)*$"
    },
    "generatedBy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sdkVersion",
        "cliVersion"
      ],
      "properties": {
        "sdkVersion": {
          "$ref": "#/$defs/exactVersion"
        },
        "cliVersion": {
          "$ref": "#/$defs/exactVersion"
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "configPath",
        "configSemanticSha256"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/stableId"
        },
        "configPath": {
          "$ref": "#/$defs/relativePath"
        },
        "configSemanticSha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "catalogRevision",
        "catalogSha256"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/stableId"
        },
        "catalogRevision": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "catalogSha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "role",
        "version",
        "source",
        "identity",
        "lockEntrySha256"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/stableId"
        },
        "role": {
          "enum": [
            "compiler",
            "dependency-manager",
            "package-manager",
            "runtime",
            "sdk",
            "build-tool"
          ]
        },
        "version": {
          "$ref": "#/$defs/exactVersion"
        },
        "source": {
          "enum": [
            "co-located",
            "git-source",
            "npm-release",
            "haxelib-release",
            "oci-image"
          ]
        },
        "identity": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "lockEntrySha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "packageFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "packageGraph": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manager",
        "version",
        "manifest",
        "lockfile",
        "lifecycleScriptsAllowed"
      ],
      "properties": {
        "manager": {
          "const": "npm"
        },
        "version": {
          "$ref": "#/$defs/exactVersion"
        },
        "manifest": {
          "$ref": "#/$defs/packageFile"
        },
        "lockfile": {
          "$ref": "#/$defs/packageFile"
        },
        "lifecycleScriptsAllowed": {
          "type": "boolean"
        }
      }
    }
  }
}
