{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wordpress-hx.semantic-node.wordpress.module.v1",
  "title": "WordPressHx module semantic node payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "moduleId",
    "moduleType",
    "displayName",
    "version",
    "namespace"
  ],
  "properties": {
    "moduleId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "moduleType": {
      "enum": [
        "plugin",
        "mu-plugin",
        "theme",
        "block"
      ]
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
    },
    "namespace": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9]*(?:\\\\[A-Z][A-Za-z0-9]*)*$"
    }
  }
}
