{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wordpress-hx.dev/schemas/scaffold-plan.schema.json",
  "title": "WordPressHx scaffold plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "operation",
    "kind",
    "projectId",
    "profile",
    "entryPoint",
    "target",
    "dryRun",
    "status",
    "files",
    "limitations"
  ],
  "properties": {
    "schema": {
      "const": "wordpress-hx.scaffold-plan.v1"
    },
    "operation": {
      "enum": [
        "new-site",
        "new-plugin",
        "init-site"
      ]
    },
    "kind": {
      "enum": [
        "site",
        "plugin"
      ]
    },
    "projectId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
      "maxLength": 64
    },
    "profile": {
      "const": "wp70-release"
    },
    "entryPoint": {
      "type": "string",
      "pattern": "^[a-z][A-Za-z0-9_]*(?:\\.[a-z][A-Za-z0-9_]*)*\\.Site$"
    },
    "target": {
      "$ref": "#/$defs/projectId"
    },
    "dryRun": {
      "type": "boolean"
    },
    "status": {
      "enum": [
        "planned",
        "published"
      ]
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/file"
      }
    },
    "limitations": {
      "oneOf": [
        {
          "const": [
            "native-target-producers-not-registered",
            "public-package-installation-blocked"
          ]
        },
        {
          "const": [
            "plugin-bootstrap-only",
            "public-package-installation-blocked"
          ]
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "operation": {
            "const": "new-plugin"
          }
        },
        "required": [
          "operation"
        ]
      },
      "then": {
        "properties": {
          "kind": {
            "const": "plugin"
          },
          "limitations": {
            "const": [
              "plugin-bootstrap-only",
              "public-package-installation-blocked"
            ]
          }
        }
      },
      "else": {
        "properties": {
          "kind": {
            "const": "site"
          },
          "limitations": {
            "const": [
              "native-target-producers-not-registered",
              "public-package-installation-blocked"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "projectId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
      "maxLength": 64
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*\\\\)(?!.*:)[ -~]+$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "action",
        "ownership",
        "mode",
        "sha256",
        "sizeBytes"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "action": {
          "enum": [
            "create",
            "update-marker"
          ]
        },
        "ownership": {
          "enum": [
            "authored",
            "cli-owned"
          ]
        },
        "mode": {
          "const": 420
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 0
        },
        "beforeSha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "const": "update-marker"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "beforeSha256"
            ]
          },
          "else": {
            "not": {
              "required": [
                "beforeSha256"
              ]
            }
          }
        }
      ]
    }
  }
}
