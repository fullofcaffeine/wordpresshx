  "sourceStates": [
    {
      "id": "untrusted",
      "meaning": "a value crossed an input, persistence, provider, or network boundary",
      "outputAuthority": false
    },
    {
      "id": "validated",
      "meaning": "a value satisfied a domain predicate without mutation",
      "outputAuthority": false
    },
    {
      "id": "sanitized",
      "meaning": "a value was deliberately transformed under one named input policy",
      "outputAuthority": false
    },
    {
      "id": "domain-value",
      "meaning": "an application value whose domain type is known",
      "outputAuthority": false
    }
  ],
  "contexts": [
